{
  "name": "pylomarket",
  "version": "1.0.0",
  "description": "PyloMarket - Prediction Markets Platform with HarperDB and Next.js",
  "private": true,
  "scripts": {
    "start": "harperdb-nextjs start",
    "dev": "harperdb-nextjs dev",
    "build": "harperdb-nextjs build",
    "login": "node login.js",
    "deploy": "npx -y dotenv-cli -- harperdb deploy . restart=rolling replicated=true",
    "lint": "next lint",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@harperdb/nextjs": "^1.1.4",
    "@solana/web3.js": "^1.98.4",
    "bcryptjs": "^3.0.3",
    "harperdb": "latest",
    "jsonwebtoken": "^9.0.3",
    "next": "16.1.4",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "patch-package": "^8.0.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
