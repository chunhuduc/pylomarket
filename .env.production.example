# Production Environment Variables
# Copy this file to .env.production on your VPS and fill in the values

# HarperDB Configuration
HARPERDB_USERNAME=HDB_ADMIN
HARPERDB_PASSWORD=your-secure-password-here
HARPERDB_URL=http://harperdb:9925

# Next.js Configuration
NEXT_PUBLIC_HARPERDB_URL=http://your-domain.com:9925
# Or use your VPS IP if no domain:
# NEXT_PUBLIC_HARPERDB_URL=http://123.456.789.0:9925

# Solana Configuration
SOLANA_RPC_URL=https://api.devnet.solana.com
# For production, you might want to use mainnet:
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=devnet
# For production:
# NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta

# JWT Secret (IMPORTANT: Use a strong random string)
JWT_SECRET=your-very-secure-random-jwt-secret-key-here

# Node Environment
NODE_ENV=production
